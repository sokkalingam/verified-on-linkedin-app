# Supabase Configuration
# Get these from your Supabase project settings (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-publishable-key"

# Alternative environment variable names (for compatibility)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-publishable-key"

# LinkedIn OAuth Configuration
# Get these from your LinkedIn app settings
LINKEDIN_CLIENT_ID="your-client-id"
LINKEDIN_CLIENT_SECRET="your-client-secret"
REDIRECT_URI="http://localhost:3000/callback"

# Server Configuration
PORT=3000
NODE_ENV="development"

# Table Selection (automatic based on NODE_ENV)
# - NODE_ENV=development → uses 'usage_logs_local' table
# - NODE_ENV=production → uses 'usage_logs' table
# This allows separate tracking for local testing and production
